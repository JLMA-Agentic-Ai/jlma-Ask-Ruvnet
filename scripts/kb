#!/bin/bash
# Knowledge Base CLI - Direct PostgreSQL Access
# Usage: kb <command> [schema] [args...]
#
# Updated: 2025-12-29 00:00:00 EST | Version 1.0.0
# Created: 2025-12-29 00:00:00 EST
#
# This script provides CLI access to the ruvector-kb PostgreSQL knowledge base.
# It wraps psql commands for common operations like semantic search, retrieval,
# and statistics.
#
# INSTALLATION:
#   chmod +x scripts/kb
#   ln -sf "$(pwd)/scripts/kb" ~/.local/bin/kb
#
# USAGE:
#   kb search askruvnet "agent spawning patterns"
#   kb get askruvnet 42
#   kb stats askruvnet
#   kb schemas
#   kb ingest askruvnet "Title" "Content" "source.md"

set -e

# Configuration
PGPASSWORD="${RUVECTOR_KB_PASSWORD:-${RUVECTOR_PASSWORD:-}}"
PGHOST="${RUVECTOR_KB_HOST:-localhost}"
PGPORT="${RUVECTOR_KB_PORT:-5435}"
PGUSER="${RUVECTOR_KB_USER:-postgres}"
PGDB="${RUVECTOR_KB_DATABASE:-postgres}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Allowed schemas (for validation)
ALLOWED_SCHEMAS="askruvnet presenter_mode ruvector_test"

validate_schema() {
    local schema="$1"
    if ! echo "$ALLOWED_SCHEMAS" | grep -qw "$schema"; then
        echo -e "${RED}Error: Invalid schema '$schema'${NC}" >&2
        echo "Allowed schemas: $ALLOWED_SCHEMAS" >&2
        exit 1
    fi
}

run_query() {
    PGPASSWORD="$PGPASSWORD" psql -h "$PGHOST" -p "$PGPORT" -U "$PGUSER" -d "$PGDB" \
        --pset=border=2 --pset=linestyle=unicode -c "$1"
}

run_query_quiet() {
    PGPASSWORD="$PGPASSWORD" psql -h "$PGHOST" -p "$PGPORT" -U "$PGUSER" -d "$PGDB" \
        -t -A -c "$1"
}

case "${1:-help}" in
    search)
        SCHEMA="${2:-askruvnet}"
        validate_schema "$SCHEMA"
        shift 2
        QUERY="$*"

        if [ -z "$QUERY" ]; then
            echo -e "${RED}Error: Search query required${NC}" >&2
            echo "Usage: kb search <schema> <query>" >&2
            exit 1
        fi

        echo -e "${BLUE}Searching '$SCHEMA' for: $QUERY${NC}"
        echo ""

        # Escape single quotes in query
        QUERY_ESCAPED=$(echo "$QUERY" | sed "s/'/''/g")

        # Note: real[] must be converted to ruvector type for <=> operator
        # Format: ('[' || array_to_string(embedding, ',') || ']')::ruvector
        run_query "
            SELECT
                id,
                title,
                LEFT(content, 150) || CASE WHEN LENGTH(content) > 150 THEN '...' ELSE '' END as preview,
                ROUND((1 - (
                    ('[' || array_to_string(embedding, ',') || ']')::ruvector
                    <=>
                    ('[' || array_to_string(ruvector_embed('$QUERY_ESCAPED'), ',') || ']')::ruvector
                ))::numeric, 3) as score
            FROM $SCHEMA.guru_knowledge
            WHERE embedding IS NOT NULL
            ORDER BY
                ('[' || array_to_string(embedding, ',') || ']')::ruvector
                <=>
                ('[' || array_to_string(ruvector_embed('$QUERY_ESCAPED'), ',') || ']')::ruvector
            LIMIT 10;
        "
        ;;

    get)
        SCHEMA="${2:-askruvnet}"
        validate_schema "$SCHEMA"
        ID="$3"

        if [ -z "$ID" ]; then
            echo -e "${RED}Error: ID required${NC}" >&2
            echo "Usage: kb get <schema> <id>" >&2
            exit 1
        fi

        echo -e "${BLUE}Retrieving entry #$ID from '$SCHEMA'${NC}"
        echo ""

        run_query "
            SELECT
                id,
                title,
                content,
                source,
                created_at
            FROM $SCHEMA.guru_knowledge
            WHERE id = $ID;
        "
        ;;

    stats)
        SCHEMA="${2:-askruvnet}"
        validate_schema "$SCHEMA"

        echo -e "${BLUE}Statistics for '$SCHEMA'${NC}"
        echo ""

        run_query "
            SELECT
                '$SCHEMA' as schema,
                COUNT(*) as total_vectors,
                COUNT(CASE WHEN embedding IS NOT NULL THEN 1 END) as with_embeddings,
                pg_size_pretty(pg_total_relation_size('$SCHEMA.guru_knowledge')) as total_size,
                pg_size_pretty(SUM(pg_column_size(content))) as content_size,
                pg_size_pretty(SUM(pg_column_size(embedding))) as embedding_size,
                MIN(created_at)::date as oldest_entry,
                MAX(created_at)::date as newest_entry
            FROM $SCHEMA.guru_knowledge;
        "
        ;;

    schemas)
        echo -e "${BLUE}Available Knowledge Base Schemas${NC}"
        echo ""

        run_query "
            SELECT
                n.nspname as schema,
                COUNT(c.relname) as tables,
                pg_size_pretty(SUM(pg_total_relation_size(c.oid))) as total_size
            FROM pg_namespace n
            LEFT JOIN pg_class c ON c.relnamespace = n.oid AND c.relkind = 'r'
            WHERE n.nspname NOT IN ('pg_catalog', 'information_schema', 'pg_toast', 'public')
            GROUP BY n.nspname
            ORDER BY n.nspname;
        "
        ;;

    ingest)
        SCHEMA="${2:-askruvnet}"
        validate_schema "$SCHEMA"
        TITLE="$3"
        CONTENT="$4"
        SOURCE="${5:-manual}"

        if [ -z "$TITLE" ] || [ -z "$CONTENT" ]; then
            echo -e "${RED}Error: Title and content required${NC}" >&2
            echo "Usage: kb ingest <schema> <title> <content> [source]" >&2
            exit 1
        fi

        # Escape single quotes
        TITLE_ESCAPED=$(echo "$TITLE" | sed "s/'/''/g")
        CONTENT_ESCAPED=$(echo "$CONTENT" | sed "s/'/''/g")
        SOURCE_ESCAPED=$(echo "$SOURCE" | sed "s/'/''/g")
        EMBED_TEXT=$(echo "$TITLE $CONTENT" | sed "s/'/''/g")

        echo -e "${BLUE}Ingesting to '$SCHEMA'...${NC}"

        RESULT=$(run_query_quiet "
            INSERT INTO $SCHEMA.guru_knowledge (title, content, source, embedding)
            VALUES ('$TITLE_ESCAPED', '$CONTENT_ESCAPED', '$SOURCE_ESCAPED', ruvector_embed('$EMBED_TEXT'))
            RETURNING id;
        ")

        echo -e "${GREEN}Ingested with ID: $RESULT${NC}"
        ;;

    count)
        SCHEMA="${2:-askruvnet}"
        validate_schema "$SCHEMA"

        COUNT=$(run_query_quiet "SELECT COUNT(*) FROM $SCHEMA.guru_knowledge;")
        echo "$COUNT"
        ;;

    health)
        echo -e "${BLUE}Knowledge Base Health Check${NC}"
        echo ""

        # Check connection
        if PGPASSWORD="$PGPASSWORD" psql -h "$PGHOST" -p "$PGPORT" -U "$PGUSER" -d "$PGDB" -c "SELECT 1;" > /dev/null 2>&1; then
            echo -e "${GREEN}Connection: OK${NC}"
        else
            echo -e "${RED}Connection: FAILED${NC}"
            exit 1
        fi

        # Check extension
        EXT=$(run_query_quiet "SELECT extversion FROM pg_extension WHERE extname = 'ruvector';")
        if [ -n "$EXT" ]; then
            echo -e "${GREEN}RuVector Extension: v$EXT${NC}"
        else
            echo -e "${RED}RuVector Extension: NOT INSTALLED${NC}"
        fi

        # Check embedding function
        if run_query_quiet "SELECT ruvector_embed('test');" > /dev/null 2>&1; then
            echo -e "${GREEN}Embedding Function: OK${NC}"
        else
            echo -e "${RED}Embedding Function: FAILED${NC}"
        fi

        echo ""
        echo -e "${BLUE}Schema Summary:${NC}"
        run_query "
            SELECT
                n.nspname as schema,
                (SELECT COUNT(*) FROM pg_class c2
                 WHERE c2.relnamespace = n.oid AND c2.relkind = 'r'
                 AND c2.relname LIKE '%knowledge%') as knowledge_tables
            FROM pg_namespace n
            WHERE n.nspname NOT IN ('pg_catalog', 'information_schema', 'pg_toast', 'public')
            ORDER BY n.nspname;
        "
        ;;

    models)
        echo -e "${BLUE}Available Embedding Models${NC}"
        echo ""
        run_query "SELECT * FROM ruvector_embedding_models();"
        ;;

    help|--help|-h|*)
        echo -e "${BLUE}Knowledge Base CLI${NC}"
        echo ""
        echo "Usage: kb <command> [schema] [args...]"
        echo ""
        echo "Commands:"
        echo "  search <schema> <query>     Semantic search in knowledge base"
        echo "  get <schema> <id>           Retrieve entry by ID"
        echo "  stats <schema>              Show schema statistics"
        echo "  schemas                     List available schemas"
        echo "  ingest <schema> <t> <c> [s] Add new knowledge entry"
        echo "  count <schema>              Count entries (quiet output)"
        echo "  health                      Check database health"
        echo "  models                      List embedding models"
        echo "  help                        Show this help"
        echo ""
        echo "Available schemas: $ALLOWED_SCHEMAS"
        echo ""
        echo "Examples:"
        echo "  kb search askruvnet 'agent spawning patterns'"
        echo "  kb get askruvnet 42"
        echo "  kb stats askruvnet"
        echo "  kb ingest askruvnet 'Title' 'Content here' 'source.md'"
        echo ""
        echo "Environment Variables:"
        echo "  RUVECTOR_KB_HOST     PostgreSQL host (default: localhost)"
        echo "  RUVECTOR_KB_PORT     PostgreSQL port (default: 5435)"
        echo "  RUVECTOR_KB_USER     PostgreSQL user (default: postgres)"
        echo "  RUVECTOR_KB_PASSWORD PostgreSQL password"
        echo "  RUVECTOR_KB_DATABASE Database name (default: postgres)"
        ;;
esac
