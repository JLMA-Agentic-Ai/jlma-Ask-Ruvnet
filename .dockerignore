# Secrets — NEVER include in Docker image
.env
.env.*
*.pem
*.key

# Development artifacts
.git
.claude
.github
.vscode
.idea
*.swp

# Node modules (reinstalled in Docker)
node_modules
src/ui/node_modules

# Build artifacts
*.log
coverage/
.nyc_output/

# Databases (not needed at runtime)
*.db

# Heavy directories (not needed at runtime)
data_ingestion_ruv_coaching
data_ingestion_github
archive
generated_imgs
strange-loop-research
workspace
logs
.ruvector
.hive-mind
.swarm
.claude-flow
.agentic-flow
docs

# Large files (knowledge.rvf is committed at 535KB — only that version should be used)
knowledge.rvf.idmap.json

# Uncompressed browser assets (gzipped versions are sufficient)
src/ui/public/assets/knowledge-sq8.bin
src/ui/public/assets/knowledge-meta.json
src/ui/public/assets/knowledge-sq8-params.bin

# Service account keys
config/service-account.json
config/
